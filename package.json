{
  "name": "fca-app",
  "version": "1.0.0",
  "description": "FCA Application - Assessment Platform",
  "scripts": {
    "dev": "next dev",
    "dev:backend": "ts-node src/adapters/http/index.ts",
    "start:backend:qa": "ts-node src/adapters/http/index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc -p tsconfig.api.json --noEmit",
    "test": "jest --runInBand",
    "test:api": "jest --runInBand --testPathIgnorePatterns=integration",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:coverage": "jest --coverage",
    "qa:bootstrap-backend": "node scripts/qa/bootstrap-backend.js",
    "qa:teardown-backend": "node scripts/qa/teardown-backend.js",
    "qa:status-backend": "node scripts/qa/status-backend.js",
    "qa:reset": "node scripts/qa/reset.js",
    "qa:seed": "node scripts/qa/seed.js",
    "qa:api": "node scripts/qa/api-runner.js"
  },
  "dependencies": {
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@vitest/ui": "^4.0.16",
    "dotenv": "^17.2.3",
    "jest": "^29.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^4.0.16"
  }
}